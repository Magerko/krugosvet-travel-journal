# Скопируй в .env и подставь свои значения перед запуском в проде
# (docker-compose.yml читает из этого файла).
#
# В dev-режиме (docker compose up без -f) override.yml подставит слабые
# тестовые значения, но в проде .env обязателен.

# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замените-на-длинную-случайную-строку

# Пароли MySQL. НЕ оставляйте дефолты в проде.
MYSQL_ROOT_PASSWORD=замените-на-длинный-пароль
MYSQL_PASSWORD=замените-на-длинный-пароль
MYSQL_USER=krugosvet
MYSQL_DATABASE=krugosvet

# Режим: prod (gunicorn) или dev (flask с автоперезагрузкой).
APP_MODE=prod

# Порты на хосте (можно поменять, если 5000/3307 заняты).
APP_HOST_PORT=5000
DB_HOST_PORT=3307
